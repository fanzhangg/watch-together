# Keep the build context small and never bake local state or secrets into the image.

# Secrets — the image must get config from env vars at run time, not a baked .env
**/.env
**/.env.*
!**/.env.example

# Python local state
**/__pycache__/
**/*.py[cod]
backend/.venv/
backend/.pytest_cache/
backend/.mypy_cache/

# Local databases. NOTE the leading **/ — a bare "*.db" only matches the context
# ROOT, so backend/dev.db would still be copied into the image (it was).
**/*.db
**/*.sqlite
**/*.sqlite3

# Node / build output (the image builds these itself)
frontend/node_modules/
frontend/dist/
frontend/test-results/
frontend/playwright-report/
backend/app/web/

# Repo / tooling
.git/
.gitignore
.github/
docs/
*.md
.vscode/
.idea/
