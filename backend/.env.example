# Copy to backend/.env for local dev. Never commit the real .env.

# Neon pooled connection string (postgresql://...). Leave blank to run the
# API without a database (health check still works).
DB_URL=

# Session cookie signing secret (any long random string in dev).
SESSION_SECRET=dev-insecure-secret-change-me

# Local-only login bypass so the UI can be built before Google OAuth is set up.
DEV_LOGIN=true

# Google OAuth client id (M1+). Get from Google Cloud Console.
GOOGLE_CLIENT_ID=

# TMDB API key (M3+). Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=
